AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_single_page_app_client_id
AUTH0_AUDIENCE=https://myguitarlesson/api
VERCEL_TOKEN=your_vercel_deploy_token
VERCEL_PROJECT_NAME=acoustic-steps

# Optional local SQLite path. Defaults to ./data/acoustic-steps.sqlite locally
# and /tmp/acoustic-steps.sqlite on Vercel serverless functions.
SQLITE_PATH=
